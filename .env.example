# Ollama service URL (change only if running Ollama outside Docker Compose)
OLLAMA_BASE_URL=http://ollama:11434

# Default model to use for inference.
# tinyllama is the smallest/fastest model — great for low-resource hardware.
# Other options: phi3:mini, gemma:2b, qwen:0.5b
DEFAULT_MODEL=tinyllama

# Number of parallel uvicorn worker processes for the FastAPI service.
# 4 is a good starting point; increase for machines with more CPU cores.
WEB_CONCURRENCY=4

# Number of requests Ollama will process simultaneously.
# Increase to allow multiple users to receive streamed responses at the same time.
# Higher values consume more VRAM/RAM. Start with 4 and tune to your hardware.
OLLAMA_NUM_PARALLEL=4
